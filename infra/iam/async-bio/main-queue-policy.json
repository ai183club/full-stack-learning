{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowOnlyProfileDomainTopic",
      "Effect": "Allow",
      "Principal": { "Service": "sns.amazonaws.com" },
      "Action": "sqs:SendMessage",
      "Resource": "arn:aws:sqs:ap-northeast-1:017719539487:profile-bio-generation-queue",
      "Condition": {
        "ArnEquals": {
          "aws:SourceArn": "arn:aws:sns:ap-northeast-1:017719539487:profile-domain-events"
        },
        "StringEquals": { "aws:SourceAccount": "017719539487" }
      }
    }
  ]
}
